# Skopiuj do `.env` i uzupełnij. Plik `.env` NIE trafia do gita (patrz .gitignore).
#
# CENY przy każdej usłudze to ORIENTACYJNE stawki z mojej wiedzy (mogą być nieaktualne —
# zweryfikuj u dostawcy). „UŻYWANE" = wołane w kodzie, „ZAPAS/OPCJONALNE" = tylko fallback.
# Koszt modeli AI (Claude/OpenAI) jest policzony dokładnie w runtime i widać go w 📊.

# Token aplikacji — USTAW TYLKO W CHMURZE (publiczny endpoint). Gdy ustawiony, każdy
# request poza /health musi mieć nagłówek `x-app-token` = ta wartość. Lokalnie zostaw
# pusty, żeby dev/LAN działał bez tokena. Tę samą wartość wpisz w apce jako
# EXPO_PUBLIC_APP_TOKEN. Wygeneruj np.:  openssl rand -hex 24
APP_TOKEN=

# Claude API — https://console.anthropic.com/ → API Keys
# UŻYWANE (rdzeń: skan menu, opisy dań, weryfikacja zdjęć). Cena $/1M tok (w models.ts):
#   Sonnet 4.6 ~$3 in / $15 out ; Opus 4.8 ~$5 in / $25 out.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (modele GPT-5 do porównań) — OPCJONALNE. Bez tego modele OpenAI
# w apce zwrócą błąd, a Claude działa normalnie. https://platform.openai.com/api-keys
# Cena $/1M tok (w models.ts):  GPT-5 ~$1.25 in / $10 out ; GPT-5 mini ~$0.25 in / $2 out.
OPENAI_API_KEY=

# Google Programmable Search Engine (wyszukiwanie zdjęć dań — tryb osobisty) — OPCJONALNE.
#   Klucz API:  https://developers.google.com/custom-search/v1/overview
#   CX (ID wyszukiwarki, z włączonym "Image search" i "Search the entire web"):
#               https://programmablesearchengine.google.com/
#   Cena: 100 zapytań/dzień darmo, potem ~$5/1000 (limit 10k/dzień).
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# Serper.dev (Google Images) — UŻYWANE, główne wyszukiwanie zdjęć dań.
# Cena: 2500 darmowych zapytań, potem ~$0.30-1/1000 (taniej przy wolumenie). https://serper.dev
SERPER_KEY=

# SerpApi (Google Images) — ZAPAS (fallback). Cena: 100/mies. darmo, plany od ~$75/mies
# (~$15/1000). https://serpapi.com
SERPAPI_KEY=

# Google Places (identyfikacja restauracji + zdjęcia lokalu) — UŻYWANE.
# Cena per SKU (Maps Platform, ~$/1000 wywołań): Place Details ~$17, Place Photos ~$7,
# Text/Nearby Search ~$32 (+ miesięczny darmowy limit Google). Zweryfikuj aktualny cennik.
GOOGLE_MAPS_KEY=

# TripAdvisor Content API (ocena + link na stronę lokalu) — UŻYWANE. Cena: darmowe
# (limit ~kilka–kilkanaście tys./mies.), wymaga zatwierdzonej rejestracji:
# https://developer-tripadvisor.com/content-api/
TRIPADVISOR_KEY=
# Gdy klucz TA jest ograniczony po HTTP referer — wartość allowlisty (np. adres backendu).
# Serwer wyśle ten Referer/Origin. Zostaw puste przy ograniczeniu po IP / bez ograniczeń.
TRIPADVISOR_REFERER=

# Wikimedia Commons + Openverse — UŻYWANE jako fallback zdjęć poglądowych. DARMOWE,
# bez klucza (nie ma tu zmiennej) — wymagają tylko porządnego User-Agenta (już ustawiony).
