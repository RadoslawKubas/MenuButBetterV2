# Skopiuj do `.env` i uzupełnij. Plik `.env` NIE trafia do gita (patrz .gitignore).

# Token aplikacji — USTAW TYLKO W CHMURZE (publiczny endpoint). Gdy ustawiony, każdy
# request poza /health musi mieć nagłówek `x-app-token` = ta wartość. Lokalnie zostaw
# pusty, żeby dev/LAN działał bez tokena. Tę samą wartość wpisz w apce jako
# EXPO_PUBLIC_APP_TOKEN. Wygeneruj np.:  openssl rand -hex 24
APP_TOKEN=

# Claude API — https://console.anthropic.com/ → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API (modele GPT-5 do porównań) — OPCJONALNE. Bez tego modele OpenAI
# w apce zwrócą błąd, a Claude działa normalnie. https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Programmable Search Engine (wyszukiwanie zdjęć dań — tryb osobisty)
#   Klucz API:  https://developers.google.com/custom-search/v1/overview
#   CX (ID wyszukiwarki, z włączonym "Image search" i "Search the entire web"):
#               https://programmablesearchengine.google.com/
GOOGLE_CSE_KEY=
GOOGLE_CSE_CX=

# Serper.dev (Google Images) — REKOMENDOWANE: 2500 darmowych zapytań, potem ~$0.30-1/1000.
# https://serper.dev
SERPER_KEY=

# SerpApi (Google Images) — zapas. Darmowo 100/mies.: https://serpapi.com
SERPAPI_KEY=

# Google Places (identyfikacja restauracji + zdjęcia lokalu)
GOOGLE_MAPS_KEY=

# TripAdvisor Content API (ocena + link na stronę lokalu) — darmowe, wymaga
# zatwierdzonej rejestracji: https://developer-tripadvisor.com/content-api/
TRIPADVISOR_KEY=
# Gdy klucz TA jest ograniczony po HTTP referer — wartość allowlisty (np. adres backendu).
# Serwer wyśle ten Referer/Origin. Zostaw puste przy ograniczeniu po IP / bez ograniczeń.
TRIPADVISOR_REFERER=
