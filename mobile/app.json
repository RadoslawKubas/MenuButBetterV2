{
  "expo": {
    "name": "MenuButBetter",
    "slug": "menubutbetter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "MenuButBetter potrzebuje dostępu do zdjęć, aby wczytać menu z galerii.",
          "cameraPermission": "MenuButBetter używa aparatu do zrobienia zdjęcia menu."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MenuButBetter używa lokalizacji tylko gdy zaznaczysz, że jesteś w restauracji, aby ją namierzyć."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "MenuButBetter potrzebuje dostępu do zdjęć, aby wczytać menu z galerii.",
          "savePhotosPermission": "MenuButBetter zapisuje zrobione zdjęcia menu w Twojej galerii (tryb testowy).",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.appwithkiss.menubutbetter.lab",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#115E59",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "ac10d674-691e-461b-ae59-37109a6aecc5"
      }
    },
    "owner": "kedarsabuk"
  }
}
